FROM python:3.12-slim

WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Pre-install dependencies (cached layer, reinstalled at runtime for editable mode)
COPY pyproject.toml .
RUN uv pip install --system -e ".[dev]"

# Source is volume-mounted at runtime
CMD ["sh", "-c", "uv pip install --system -e '.[dev]' && alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"]
